---
import Base from "../layouts/Base.astro";
import Catalog from "../components/Catalog.tsx";
import { loadPackages } from "../lib/catalog";

const packages = loadPackages();
---

<Base
  title="grim package index"
  description="Browse and search AI-config packages — skills, rules, agents, MCP servers, and bundles — installable with the grim package manager."
>
  <div class="hero">
    <h1>grim package index</h1>
    <p>
      Skills, rules, agents, MCP servers, and bundles for AI coding agents,
      hosted on OCI registries. Copy an <code>add</code> command below — or{
        " "
      }<a href="https://grimoire.rs/installation.html">install grim</a> first:
    </p>
    <div class="install">
      <div class="install-row">
        <span class="os">Linux / macOS</span>
        <code>curl --proto '=https' --tlsv1.2 -LsSf https://setup.grimoire.rs/sh | sh</code>
        <button
          type="button"
          class="copy"
          data-copy="curl --proto '=https' --tlsv1.2 -LsSf https://setup.grimoire.rs/sh | sh"
          aria-label="Copy the Linux/macOS install command"
        >
          <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
            <path
              fill="currentColor"
              d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"
            ></path>
            <path
              fill="currentColor"
              d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"
            ></path>
          </svg>
          <span>copy</span>
        </button>
      </div>
      <div class="install-row">
        <span class="os">Windows</span>
        <code>irm https://setup.grimoire.rs/ps1 | iex</code>
        <button
          type="button"
          class="copy"
          data-copy="irm https://setup.grimoire.rs/ps1 | iex"
          aria-label="Copy the Windows install command"
        >
          <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
            <path
              fill="currentColor"
              d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"
            ></path>
            <path
              fill="currentColor"
              d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"
            ></path>
          </svg>
          <span>copy</span>
        </button>
      </div>
    </div>
  </div>

  <script>
    for (const btn of document.querySelectorAll<HTMLButtonElement>(
      "button[data-copy]",
    )) {
      btn.addEventListener("click", () => {
        navigator.clipboard.writeText(btn.dataset.copy ?? "").then(() => {
          const label = btn.querySelector("span");
          btn.classList.add("copied");
          if (label) label.textContent = "copied";
          setTimeout(() => {
            btn.classList.remove("copied");
            if (label) label.textContent = "copy";
          }, 1500);
        });
      });
    }
  </script>
  <Catalog client:load packages={packages} />
</Base>
